# API для приёма заявок. URL Webhook из n8n или ваш backend.
# Локальный n8n (после импорта workflow и активации): http://localhost:5678/webhook/lead
VITE_LEAD_API=http://localhost:5678/webhook/lead

# Gemini API для AI-ассистента (опционально)
# VITE_GEMINI_API_KEY=
# 1. Запустить n8n
npm run n8n

# 2. Открыть http://localhost:5678, импортировать docs/n8n-lead-workflow.json и активировать workflow

# 3. Запустить сайт
npm run dev

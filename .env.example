# Ссылка на Telegram-бота (кнопка в секции Контакты)
# VITE_TG_BOT_LINK=https://t.me/vozduh_nsk_bot

# API для приёма заявок. URL Webhook из n8n или ваш backend.
# Локальный n8n (после импорта workflow и активации): http://localhost:5678/webhook/lead
VITE_LEAD_API=http://localhost:5678/webhook/lead

# YandexGPT API для AI-ассистента и AI-генератора ТЗ (опционально)
# Обязателен folder id и один из способов авторизации: API key или IAM token.
# VITE_YANDEX_FOLDER_ID=
# VITE_YANDEX_API_KEY=
# VITE_YANDEX_IAM_TOKEN=
# VITE_YANDEX_GPT_MODEL=yandexgpt-lite
# VITE_YANDEX_GPT_MODEL_URI=gpt://<folder_id>/yandexgpt-lite/latest
